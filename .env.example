# Rocky的大模型日报 - 环境变量配置

# 阿里云 DashScope API Key (必填)
# 获取地址: https://dashscope.console.aliyun.com/ → API-KEY管理
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# HuggingFace API Token (可选, 用于获取更多模型数据)
# 获取地址: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# 报告输出目录 (可选, 默认为 ./reports)
OUTPUT_DIR=./reports

# 日志级别 (可选: DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
